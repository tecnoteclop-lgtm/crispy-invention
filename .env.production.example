# Production environment variables
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32"
NEXTAUTH_URL="https://your-domain.com"
APP_BASE_URL="https://your-domain.com"

# PostgreSQL (required for production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tastegraph?sslmode=require"

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
# IMPORTANT: Switch to SIGNED uploads before going public (see HARDENING.md)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your_signed_upload_preset"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Optional observability
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN=""

# Email provider (required for password reset & email verification)
EMAIL_FROM="hello@your-domain.com"
RESEND_API_KEY=""

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
